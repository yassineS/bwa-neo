/*
 * Nextflow config for at-scale bwa-neo validation.
 * Use: nextflow run main.nf -profile standard
 */
params {
    outdir = 'results'
    bwa_neo = "${projectDir}/../../../bwa"
    bwa_baseline = ''  // path to lh3/bwa binary; set via CLI or env
    bwa_mem2 = ''    // path to bwa-mem2 binary
    ref_fa = ''      // optional: local reference; else download via params
    threads_aln = 1
    threads_samse = 1
    threads_sampe = 1
    threads_mem = 4
    // Deterministic parity: keep threading at 1 for SAM identity unless testing scaling only
}

profiles {
    standard {
        process.executor = 'local'
    }
    // slurm { process.executor = 'slurm' ... }
}
