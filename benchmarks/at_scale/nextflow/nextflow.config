/*
 * Nextflow config for at-scale bwa-neo validation.
 * Use: nextflow run main.nf -profile standard
 */
params {
    outdir = 'results'
    bwa_neo = "${projectDir}/../../../bwa"
    bwa_baseline = ''  // path to lh3/bwa binary; set via CLI or env
    bwa_mem2 = ''    // path to bwa-mem2 binary
    ref_fa = ''      // optional: local reference; else download via params
    threads_aln = 1
    threads_samse = 1
    threads_sampe = 1
    threads_mem = 4
    // Deterministic parity: keep threading at 1 for SAM identity unless testing scaling only

    // Simulation tracks (see benchmarks/at_scale/README.md — Simulation-based testing)
    enable_simulation = false
    rng_seed = 11
    sim_modern_profile = 'art_illumina_short'   // logical label; map to concrete ART/dwgsim args in workflow
    sim_ancient_profile = 'gargammel_default'   // logical label; map to gargammel/pygargammel + damage params
}

profiles {
    standard {
        process.executor = 'local'
    }
    // slurm { process.executor = 'slurm' ... }
}
