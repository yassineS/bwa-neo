/*
 * bwa-neo at-scale benchmarks — Pixi supplies Nextflow + tools (see benchmarks/at_scale/pixi.toml).
 */
params {
    outdir = 'results'

    bwa_neo = System.getenv('BWA_NEO') ?: "${projectDir}/../../../build-benchmark/bwa"
    bwa_baseline = System.getenv('BWA_BASELINE') ?: ''
    bwa_mem2 = System.getenv('BWA_MEM2') ?: ''

    ref_fa = "${projectDir}/../../../tests/fixtures/tiny/ref.fa"
    reads_fq = "${projectDir}/../../../tests/fixtures/tiny/reads.fq"
    ref_pe_fa = "${projectDir}/../../../tests/fixtures/tiny_pe/ref.fa"
    reads_pe_1 = "${projectDir}/../../../tests/fixtures/tiny_pe/r1.fq"
    reads_pe_2 = "${projectDir}/../../../tests/fixtures/tiny_pe/r2.fq"

    modern_reads_n = 1000000
    ancient_reads_n = 1000000
    thread_grid = '1 2 4 6 8'
    performance_repeats = 3
    local_publication_run = true
}

profiles {
    standard {
        process.executor = 'local'
    }
    publication {
        params {
            performance_repeats = 5
            local_publication_run = true
        }
    }
    publication_local_scale {
        params {
            performance_repeats = 3
            local_publication_run = true
        }
    }
    neo_only {
        params {
            local_publication_run = false
        }
    }
}
